import java.util.*;
class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        long sum=0;
        long max=Long.MIN_VALUE;
        for(int i=0;i<n;i++){
            long x=sc.nextLong();
            sum+=x;
            if(sum>max)
            max=sum;
            if(sum<0)
            sum=0;
            
        }
        System.out.println(max);
    }
}
