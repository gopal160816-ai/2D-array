import java.util.*;
class Main{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int [][]m=new int[n][n];
        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){
                m[i][j]=sc.nextInt();
            }
        }
        int p=0;
        int s=0;
        for(int i=0;i<n;i++){
            p+=m[i][i];
            s+=m[i][n-1-i];
        }
        System.out.println("p"+p);
        System.out.println("s"+s);
    }
}
